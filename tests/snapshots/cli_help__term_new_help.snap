---
Create a term

Usage: mf term new [OPTIONS] [TERM]

Arguments:
  [TERM]  Canonical term name. Pass positionally; the deprecated `--term` flag still parses for one
          release with a WARN

Options:
      --root <PATH>
          Mind Repo root directory
      --config <PATH>
          Config file path
      --definition <DEFINITION>
          
      --description <DESCRIPTION>
          
  -v, --verbose...
          Verbose output
      --confidence <CONFIDENCE>
          
  -q, --quiet
          Silence non-error output
      --alias <ALIAS>
          
      --format <FORMAT>
          Output format [default: text] [possible values: text, json]
      --json
          Shorthand for --format json
      --tag <TAG>
          
      --misrecognition <MISRECOGNITION>
          
      --no-color
          Disable colored output
      --dry-run
          
  -p, --project <NAME>
          Project name for project-scoped operations
      --install-completion <INSTALL_COMPLETION>
          Install shell completion script [possible values: bash, zsh, fish, powershell, elvish]
      --show-completion <SHOW_COMPLETION>
          Show shell completion script [possible values: bash, zsh, fish, powershell, elvish]
  -h, --help
          Print help
  -V, --version
          Print version
