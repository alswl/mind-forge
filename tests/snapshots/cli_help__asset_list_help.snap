source: tests/cli_help.rs
expression: stdout
---
List assets

Usage: mf asset list [OPTIONS]

Options:
      --filter <FILTER>    
      --root <PATH>        Mind Repo root directory
      --config <PATH>      Config file path
      --type <ASSET_TYPE>  [possible values: image, video, audio, other]
      --no-headers         Suppress the table header row
  -v, --verbose...         Verbose output
      --no-trunc           Disable column truncation
  -q, --quiet              Silence non-error output
      --format <FORMAT>    Output format [default: text] [possible values: text, json]
      --json               Shorthand for --format json
      --no-color           Disable colored output
  -p, --project <NAME>     Project name for project-scoped operations
  -h, --help               Print help
  -V, --version            Print version
