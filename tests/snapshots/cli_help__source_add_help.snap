Add a source

Usage: mf source add [OPTIONS] <INPUT>

Arguments:
  <INPUT>  

Options:
      --name <NAME>        
      --root <PATH>        
      --config <PATH>      
      --type <KIND>        [default: auto] [possible values: auto, pdf, file, rss, web]
      --link               
  -v, --verbose...         
      --force              
  -q, --quiet              
      --project <PROJECT>  
      --format <FORMAT>    [default: text] [possible values: text, json]
      --no-color           
  -h, --help               Print help
  -V, --version            Print version
