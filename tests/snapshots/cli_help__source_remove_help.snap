---
Remove a source

Usage: mf source remove [OPTIONS] <NAME>

Arguments:
  <NAME>  

Options:
      --keep-file          
      --root <PATH>        
      --config <PATH>      
      --project <PROJECT>  
      --format <FORMAT>    [default: text] [possible values: text, json]
  -v, --verbose...         
  -q, --quiet              
      --no-color           
  -h, --help               Print help
  -V, --version            Print version
