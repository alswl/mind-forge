---
source: tests/cli_help.rs
expression: stdout
---
Add a source

Usage: mf source add [OPTIONS] <INPUT>

Arguments:
  <INPUT>  

Options:
  -n, --name <NAME>
          
      --root <PATH>
          Mind Repo root directory
      --config <PATH>
          Config file path
      --file-kind <FILE_KIND>
          File kind (mf primary). Use --source-kind for mind channel type [possible values: auto,
          pdf, file, rss, web]
      --source-kind <SOURCE_KIND>
          Source channel type (mind primary) [possible values: yuque, meeting, misc]
  -v, --verbose...
          Verbose output
  -q, --quiet
          Silence non-error output
  -t, --type <KIND>
          Deprecated: use --file-kind or --source-kind instead [possible values: auto, pdf, file,
          rss, web]
      --format <FORMAT>
          Output format [default: text] [possible values: text, json]
      --link
          
  -f, --force
          
      --json
          Shorthand for --format json
      --dry-run
          
      --no-color
          Disable colored output
  -p, --project <NAME>
          Project name for project-scoped operations
      --install-completion <INSTALL_COMPLETION>
          Install shell completion script [possible values: bash, zsh, fish, powershell, elvish]
      --show-completion <SHOW_COMPLETION>
          Show shell completion script [possible values: bash, zsh, fish, powershell, elvish]
  -h, --help
          Print help
  -V, --version
          Print version
